  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for FlowOrFlop windows",
  "windows": ["main", "camera_overlay", "application_window"],
  "permissions": [
    "core:default",
    "core:window:allow-set-size",
    "core:window:allow-start-dragging",
    "opener:default",
    "store:default"
  ]
}
